{
  "name": "elsium-ai",
  "private": true,
  "version": "0.0.0",
  "description": "A high-performance, TypeScript-first AI framework",
  "license": "MIT",
  "author": "Eric Utrera <ebutrera9103@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elsium-ai/elsium-ai.git"
  },
  "workspaces": [
    "packages/*",
    "examples/integration-test"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter '*' dev",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && bun scripts/publish.ts --registry npm",
    "bench": "bun benchmarks/run-all.ts",
    "bench:overhead": "bun benchmarks/framework-overhead.ts",
    "bench:check": "bun benchmarks/framework-overhead.ts && bun benchmarks/check-regression.ts",
    "bench:freeze": "bun benchmarks/check-regression.ts --freeze",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test:coverage": "vitest run --coverage",
    "metrics": "bun scripts/metrics.ts",
    "stats": "bun scripts/stats.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8",
    "zod": "^3.24.0"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "picomatch": ">=2.3.2",
    "brace-expansion": ">=5.0.6",
    "vite": ">=8.0.16",
    "postcss": ">=8.5.10",
    "hono": ">=4.12.21",
    "fast-uri": ">=3.1.2",
    "esbuild": ">=0.28.1",
    "js-yaml": ">=4.2.0 <5",
    "@babel/core": ">=7.29.7 <8"
  }
}
