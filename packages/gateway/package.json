{
	"name": "@elsium-ai/gateway",
	"version": "0.1.7",
	"description": "Multi-provider LLM gateway for ElsiumAI",
	"license": "MIT",
	"author": "Eric Utrera <ebutrera9103@gmail.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/elsium-ai/elsium-ai",
		"directory": "packages/gateway"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node && bun x tsc -p tsconfig.build.json --emitDeclarationOnly",
		"dev": "bun --watch src/index.ts"
	},
	"dependencies": {
		"@elsium-ai/core": "workspace:*",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	}
}
