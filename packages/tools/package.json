{
  "name": "@elsium-ai/tools",
  "version": "0.1.0",
  "description": "Tool definition and execution for ElsiumAI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun && bun x tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@elsium-ai/core": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.0",
    "typescript": "^5.7.0"
  }
}
