{
	"name": "@elsium-ai/app",
	"version": "0.4.0",
	"description": "App bootstrap, HTTP server, and API routes for ElsiumAI",
	"license": "MIT",
	"author": "Eric Utrera <ebutrera9103@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/elsium-ai/elsium-ai.git",
		"directory": "packages/app"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node && bun x tsc -p tsconfig.build.json --emitDeclarationOnly",
		"dev": "bun --watch src/index.ts"
	},
	"dependencies": {
		"@elsium-ai/core": "workspace:*",
		"@elsium-ai/gateway": "workspace:*",
		"@elsium-ai/agents": "workspace:*",
		"@elsium-ai/tools": "workspace:*",
		"@elsium-ai/observe": "workspace:*",
		"@elsium-ai/rag": "workspace:*",
		"@elsium-ai/workflows": "workspace:*",
		"@hono/node-server": "^1.19.10",
		"hono": "^4.12.4",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	}
}
