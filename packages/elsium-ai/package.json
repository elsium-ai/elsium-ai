{
	"name": "elsium-ai",
	"version": "0.8.0",
	"description": "ElsiumAI — A high-performance, TypeScript-first AI framework",
	"license": "MIT",
	"author": "Eric Utrera <ebutrera9103@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/elsium-ai/elsium-ai.git",
		"directory": "packages/elsium-ai"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node && bun x tsc -p tsconfig.build.json --emitDeclarationOnly"
	},
	"dependencies": {
		"@elsium-ai/core": "workspace:*",
		"@elsium-ai/gateway": "workspace:*",
		"@elsium-ai/agents": "workspace:*",
		"@elsium-ai/tools": "workspace:*",
		"@elsium-ai/rag": "workspace:*",
		"@elsium-ai/workflows": "workspace:*",
		"@elsium-ai/observe": "workspace:*",
		"@elsium-ai/app": "workspace:*",
		"@elsium-ai/testing": "workspace:*",
		"@elsium-ai/mcp": "workspace:*",
		"@elsium-ai/client": "workspace:*"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	}
}
