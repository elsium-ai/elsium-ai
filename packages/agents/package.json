{
	"name": "@elsium-ai/agents",
	"version": "0.1.1",
	"description": "Agent orchestration, memory, and multi-agent patterns for ElsiumAI",
	"license": "MIT",
	"author": "Eric Utrera <ebutrera9103@gmail.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/ebutrera9103/elsium-ai",
		"directory": "packages/agents"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target bun && bun x tsc -p tsconfig.build.json --emitDeclarationOnly",
		"dev": "bun --watch src/index.ts"
	},
	"dependencies": {
		"@elsium-ai/core": "workspace:*",
		"@elsium-ai/tools": "workspace:*",
		"@elsium-ai/observe": "workspace:*",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"bun-types": "^1.3.0",
		"typescript": "^5.7.0"
	}
}
